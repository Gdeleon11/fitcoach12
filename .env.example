# ---- Database (Neon PostgreSQL) ----
# Pooled connection string used at runtime (ends with ?sslmode=require&pgbouncer=true or -pooler host)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
# Direct (non-pooled) connection used for prisma migrate / db push
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# ---- NextAuth ----
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-string"
# In production set this to your Vercel URL, e.g. https://fitcoach12.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# ---- Google OAuth (optional but supported) ----
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---- IA (AI Coach, estimación de macros, rutinas, menús, análisis de fotos) ----
# Proveedor primario: Google Gemini. Clave en https://aistudio.google.com/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
# Fallback automático cuando Gemini falla o se queda sin cupo (429). Clave en https://console.groq.com/keys
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"
GROQ_VISION_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"
# Alternativa opcional: OpenAI (se usa como último recurso si está configurada).
OPENAI_API_KEY=""

# ---- IA Local vía Cloudflare Tunnel (InnovAI / Ollama) ----
# URL de tu túnel (ej. https://innovai.tusubdominio.com/v1) o IP local (ej. http://localhost:11434/v1)
OLLAMA_BASE_URL=""
# Modelo por defecto para generación de texto (rutinas, dietas)
OLLAMA_MODEL="llama3.1:latest"
# Modelo para análisis visual de imágenes
OLLAMA_VISION_MODEL="qwen2.5vl:7b"
